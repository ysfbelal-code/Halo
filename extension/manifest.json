{
  "manifest_version": 3,
  "name": "Guardian - YouTube Content Filter",
  "version": "1.0.0",
  "description": "Blocks brainrot, social engineering, risky stunts, and mature content from YouTube's For You page.",
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://*.youtube.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://*.youtube.com/*"],
      "js": ["content/interceptor-config.js", "content/scanner.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
